rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for user progress
    match /user_progress/{userId} {
      allow read, write: if true;
    }

    // Rules for user history
    match /user_history/{userId} {
      allow read, write: if true;
    }

    // Rules for user generations
    match /user_generations/{userId} {
      allow read, write: if true;
    }

    // Rules for shared solutions - ALLOW READ/WRITE BUT BLOCK DELETION 🚫
    match /solutions/{solutionId} {
      allow read, create, update: if true;
      allow delete: if false; // 🔒 Nobody can delete data from the internet
    }
  }
}
