rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for user progress documents, keyed by Clerk user ID
    match /user_progress/{userId} {
      allow read, write: if true;
    }

    // Rules for user history documents, keyed by Clerk user ID
    match /user_history/{userId} {
      allow read, write: if true;
    }

    // Rules for user generations documents, keyed by Clerk user ID
    match /user_generations/{userId} {
      allow read, write: if true;
    }

    // Rules for shared, collaborative solutions
    match /solutions/{solutionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
  }
}
